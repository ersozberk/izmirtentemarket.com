---
// src/layouts/MainLayout.astro (BU DOSYA SADECE BİR ŞABLONDUR)
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css'; // <-- BU SATIRI EKLEYİN
export interface Props {
    title: string;
    description: string; // BU SATIRI EKLEDİK
}
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | İzmir Tente Market</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
<style is:global>
	:root {
		--accent-color: #007bff;
        --text-color: #212529;
        --secondary-text-color: #6c757d;
        --border-color: #e9ecef;
	}
	html {
		font-family: 'Montserrat', sans-serif;
		background: #ffffff;
	}
	body {
		margin: 0;
        /* GÜNCELLEME: Header'ın yeni toplam yüksekliğini (90px + 160px = 250px) buraya uyguluyoruz. */
        padding-top: var(--header-total-height, 250px); 
	}
    main {
        /* Bu alanı da yeni değere göre güncelliyoruz ki footer aşağıda kalsın */
        min-height: calc(100vh - var(--header-total-height, 250px) - 110px); /* 110px footer yüksekliği varsayılarak */
    }
    .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }
</style>
<link rel="sitemap" href="/sitemap-index.xml" />
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-17555872373"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'AW-17555872373');
</script>
<body class="dark-theme">
    <Header />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>