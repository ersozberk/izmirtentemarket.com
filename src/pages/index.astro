---
// src/pages/index.astro (TÜM GÜNCELLEMELERLE SON HALİ)
import MainLayout from '../layouts/MainLayout.astro';
import AboutIntro from '../components/AboutIntro.astro';
import ServicesSlider from '../components/ServicesSlider.astro';
import ProductGallery from '../components/ProductGallery.astro';
import FaqSection from '../components/FaqSection.astro';
import ContactSection from '../components/ContactSection.astro';
import SponsorSlider from '../components/SponsorSlider.astro';
import CommitmentSection from '../components/CommitmentSection.astro';
import BlogSlider from '../components/BlogSlider.astro';
---
<MainLayout title="İZMİR TENTE MARKET - Mimari Gölgelendirme Çözümleri" description="...">

    <section class="hero-cinematic">
        <video src="videos/hero-cinematic.mp4" autoplay loop muted playsinline poster="/images/posters/hero-poster.jpg"></video>
        <div class="hero-content">
            <h1>Tasarım ve Teknolojinin Buluştuğu Konfor.</h1>
            <p></p>
            <a href="/urunler" class="btn">DAHA FAZLASI &rarr;</a>
        </div>
    </section>

    <AboutIntro />
    <ServicesSlider />
    <ProductGallery />
    <FaqSection />
    <ContactSection />
    <SponsorSlider />
    <CommitmentSection />
    <BlogSlider />

</MainLayout>
<style is:global>
    /* Hero stilleri ve Swiper için genel stiller */
    .hero-cinematic { position: relative; height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .hero-cinematic video { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); min-width: 100%; min-height: 100%; z-index: -1; object-fit: cover; }
    .hero-content { z-index: 1; text-align: center; color: white; }
    .hero-content h1 { font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 500; }
    .hero-content p { font-size: 1.2rem; margin: 1rem 0 2rem; max-width: 500px; }
    .hero-content .btn { background-color: var(--accent-color); color: white; padding: 1rem 2.5rem; border-radius: 4px; text-decoration: none; font-weight: 500; transition: background-color 0.3s ease; }
</style>
