---
import MainLayout from '../layouts/MainLayout.astro';
import AboutIntro from '../components/AboutIntro.astro';
import ServicesSlider from '../components/ServicesSlider.astro';
import ProductGallery from '../components/ProductGallery.astro';
import FaqSection from '../components/FaqSection.astro';
import ContactSection from '../components/ContactSection.astro';
import SponsorSlider from '../components/SponsorSlider.astro';
import CommitmentSection from '../components/CommitmentSection.astro';
import BlogSlider from '../components/BlogSlider.astro';
---
<MainLayout title="İZMİR TENTE MARKET - Mimari Gölgelendirme Çözümleri" description="...">

    <section class="hero-cinematic">
        <video src="videos/hero-cinematic.mp4" autoplay loop muted playsinline poster="/images/posters/hero-poster.jpg"></video>
        <div class="hero-content">
            <h1>Tasarım ve Teknolojinin Buluştuğu Konfor.</h1>
            <p></p>
            <a href="/urunler" class="btn"> ÜRÜNLER &rarr;</a>
        </div>
    </section>

    <AboutIntro />
    <ServicesSlider />
    <ProductGallery />
    <FaqSection />
    <ContactSection />
    <CommitmentSection />
    <BlogSlider />

</MainLayout>
<style is:global>
    /* TEMEL SAYFA SIFIRLAMASI - ÇOK ÖNEMLİ */
    /* Tarayıcının varsayılan boşluklarını kaldırarak taşmaları engeller */
    html, body {
        margin: 0;
        padding: 0;
        /* Bu, yatay kaydırmayı kesin olarak engeller. 
           Sorunun kök nedenini bulmak en iyisidir ama bu da güçlü bir çözümdür. */
        overflow-x: hidden;
    }

    /* HERO BÖLÜMÜ GÜNCELLEMELERİ */
   .hero-cinematic {
        position: relative; /* Bu zaten doğru, yığınlama bağlamı oluşturur */
        height: 100dvh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        /* Güvenlik için bir arka plan rengi ekleyin. Video yüklenemezse bu görünür. */
        background-color: #000; /* Veya videonuza uygun koyu bir renk */
    }

    .hero-cinematic video {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* z-index: -1; KURALINI BURADAN KALDIRIN! */
        /* Video, varsayılan z-index: auto (veya 0) ile kalacak. */
    }

    .hero-content {
        position: relative; /* Videonun üzerine çıkabilmesi için bir konumlandırma bağlamı verin. */
        z-index: 1; /* Bu değer videonun z-index'inden (auto/0) daha yüksek olduğu için önde görünecektir. */
        text-align: center;
        color: white;
        padding: 0 20px;
    }

    .hero-content h1 {
        font-size: clamp(2.5rem, 10vw, 4rem);
        font-weight: 1200; /* Daha kalın */
        color: #fff;
        text-shadow: 0 2px 8px rgba(0,0,0,0.45); /* Okunaklılık için gölge */
        letter-spacing: 0.02em;
    }

    .hero-content p {
        font-size: 1.2rem;
        margin: 1rem 0 2rem;
        max-width: 500px;
    }

    .hero-content .btn {
        background-color: var(--accent-color);
        color: white;
        padding: 1rem 2.5rem;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 500;
        transition: background-color 0.3s ease;
    }
</style>
