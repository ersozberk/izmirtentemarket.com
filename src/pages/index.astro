---
// src/pages/index.astro (TÜM GÜNCELLEMELERLE SON HALİ)
import MainLayout from '../layouts/MainLayout.astro';
import AboutIntro from '../components/AboutIntro.astro';
import ServicesSlider from '../components/ServicesSlider.astro';
import ProductGallery from '../components/ProductGallery.astro';
import FaqSection from '../components/FaqSection.astro';
import ContactSection from '../components/ContactSection.astro';
import SponsorSlider from '../components/SponsorSlider.astro';
import CommitmentSection from '../components/CommitmentSection.astro';
import BlogSlider from '../components/BlogSlider.astro';
---
<MainLayout title="İZMİR TENTE MARKET - Mimari Gölgelendirme Çözümleri" description="...">

    <section class="hero-cinematic">
        <video src="videos/hero-cinematic.mp4" autoplay loop muted playsinline poster="/images/posters/hero-poster.jpg"></video>
        <div class="hero-content">
            <h1>Tasarım ve Teknolojinin Buluştuğu Konfor.</h1>
            <p></p>
            <a href="/urunler" class="btn">DAHA FAZLASI &rarr;</a>
        </div>
    </section>

    <AboutIntro />
    <ServicesSlider />
    <ProductGallery />
    <FaqSection />
    <ContactSection />
    <SponsorSlider />
    <CommitmentSection />
    <BlogSlider />

</MainLayout>
<style is:global>
    /* TEMEL SAYFA SIFIRLAMASI - ÇOK ÖNEMLİ */
    /* Tarayıcının varsayılan boşluklarını kaldırarak taşmaları engeller */
    html, body {
        margin: 0;
        padding: 0;
        /* Bu, yatay kaydırmayı kesin olarak engeller. 
           Sorunun kök nedenini bulmak en iyisidir ama bu da güçlü bir çözümdür. */
        overflow-x: hidden;
    }

    /* HERO BÖLÜMÜ GÜNCELLEMELERİ */
    .hero-cinematic {
        position: relative;
        
        /* 100vh yerine 100dvh kullanarak mobil tarayıcı arayüzü değişikliklerine uyum sağla */
        height: 100vh; /* Eski tarayıcılar için yedek */
        height: 100dvh; /* Dinamik viewport yüksekliği */

        width: 100%; /* Genişliğin ekranı aşmamasını garantile */
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden; /* Bu kuralın burada kalması doğru */
    }

    .hero-cinematic video {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        
        /* min-width ve min-height yerine direkt width ve height kullanmak bazen daha stabil olur */
        width: 100%;
        height: 100%;

        /* object-fit: cover; en-boy oranını koruyarak alanı kaplamasını sağlar. Bu doğru. */
        object-fit: cover;
        z-index: -1;
    }

    /* Hero-content stillerinizde bir sorun görünmüyor, olduğu gibi kalabilir. */
    .hero-content {
        z-index: 1;
        text-align: center;
        color: white;
        padding: 0 20px; /* Kenarlara çok yapışmaması için küçük bir padding eklemek iyi olabilir */
    }

    .hero-content h1 {
        font-size: clamp(2.5rem, 6vw, 5rem);
        font-weight: 500;
    }

    .hero-content p {
        font-size: 1.2rem;
        margin: 1rem 0 2rem;
        max-width: 500px;
    }

    .hero-content .btn {
        background-color: var(--accent-color);
        color: white;
        padding: 1rem 2.5rem;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 500;
        transition: background-color 0.3s ease;
    }
</style>
