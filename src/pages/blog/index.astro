---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

// Tüm blog yazılarını al ve tarihe göre en yeniden eskiye sırala
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<MainLayout title="Blog | İzmir Tente Market" description="Sektördeki yenilikler, ürünlerimiz hakkında detaylı bilgiler ve bakım ipuçları. İzmir Tente Market blog sayfasını keşfedin.">
    <main class="blog-index">
        <div class="container">
            <div class="page-header">
                <h1>Blog</h1>
                <p>Sektördeki yenilikleri ve ipuçlarını takip edin.</p>
            </div>
            <div class="posts-grid">
                {sortedPosts.map(post => (
                    <a href={`/blog/${post.slug}/`} class="post-card">
                        <img src={post.data.heroImage} alt="" class="card-image"/>
                        <div class="card-content">
                            <p class="post-date">
                                {post.data.pubDate.toLocaleDateString('tr-TR', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </p>
                            <h3 class="post-title">{post.data.title}</h3>
                            <p class="post-description">{post.data.description}</p>
                            <span class="read-more">Devamını Oku →</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </main>
</MainLayout>

<style>
    .blog-index { padding: 4rem 0; }
    .page-header { text-align: center; margin-bottom: 4rem; }
    .page-header h1 { font-size: 3rem; font-weight: 600; }
    .page-header p { font-size: 1.2rem; color: #6c757d; }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }
    .post-card {
        display: block;
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .post-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }
    .card-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }
    .card-content {
        padding: 1.5rem;
    }
    .post-date {
        font-size: 0.875rem;
        color: #6c757d;
        margin-bottom: 0.5rem;
    }
    .post-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
    .post-description {
        color: #495057;
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    .read-more {
        font-weight: 500;
        color: var(--accent-color, #007bff);
    }
</style>