---
// import { Image } from 'astro:assets';
// import aboutImage from '../../public/images/hakkimizda-gorsel.jpg';

// Kayan yazıda görünecek kelimeler. Burayı dilediğiniz gibi değiştirebilirsiniz.
const keywords = [
    "Mühendislik",
    "Bioklimatik",
    "Tecrübe",
    "Pergola",
    "Kalite",
    "Tente",
];
---

<div class="scrolling-text-container" aria-hidden="true">
    <div class="scrolling-text-inner">
        {keywords.map(word => (
            <div class="scrolling-text-item">
                <span>{word}</span>
                <span class="separator">*</span>
            </div>
        ))}
        {keywords.map(word => (
            <div class="scrolling-text-item">
                <span>{word}</span>
                <span class="separator">*</span>
            </div>
        ))}
    </div>
</div>

<section class="about-intro">
    <div class="container about-intro-container">
        <div class="about-intro-image">
            {/* --- HATA DÜZELTMESİ --- */}
            {/* <Image> bileşeni yerine standart ve güvenli <img> etiketi kullanıldı. */}
            {/* Resminizin `public/images/` klasöründe olduğundan emin olun. */}
            <img src="/images/hakkimizda-gorsel.jpg" alt="İTM Architecture Ofis veya Proje Alanı" />
        </div>
        <div class="about-intro-content">
            <h2>We Are İTM Architecture</h2>
            <p>Alüminyum sektöründeki yılların tecrübesiyle, İTM Architecture markası altında yenilikçi ve sürdürülebilir çözümler sunuyoruz. Dış Mekan Sistemleri'nin lider markası olma yolunda emin adımlarla ilerliyoruz.</p>
            <a href="/hakkimizda" class="btn">DAHA FAZLASI</a>
        </div>
    </div>
</section>
<style>
    /* YENİ: Kayan Yazı Stilleri */
    .scrolling-text-container {
        width: 100%;
        overflow: hidden;
        background-color: var(--text-color, #212529);
        color: white;
        padding: 1rem 0;
        border-bottom: 1px solid var(--border-color, #e9ecef);
    }
    .scrolling-text-inner {
        display: flex;
        white-space: nowrap;
        animation: marquee 40s linear infinite;
        will-change: transform; /* Performans optimizasyonu */
    }
    .scrolling-text-item {
        display: flex;
        align-items: center;
        font-size: 1.5rem;
        font-weight: 500;
        text-transform: uppercase;
        margin-right: 2rem;
    }
    .scrolling-text-item .separator {
        color: var(--accent-color, #007bff);
        margin-left: 2rem;
        font-size: 1.5rem;
    }

    @keyframes marquee {
        from {
            transform: translateX(0%);
        }
        to {
            transform: translateX(-50%);
        }
    }

    /* Mevcut Stiller */
    .about-intro { 
        padding: 6rem 0; 
        background-color: #f8f9fa; /* Arka plan rengi eklendi */
    }
    .about-intro-container { 
        display: grid; 
        grid-template-columns: 1fr; 
        gap: 3rem; 
        align-items: center; 
    }
    .about-intro-image img { 
        border-radius: 8px; 
        width: 100%; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.1); /* Göze hoş gelen bir gölge eklendi */
    }
    .about-intro-content h2 { 
        font-size: 2.5rem; 
        font-weight: 600; /* Biraz daha kalın */
        margin-bottom: 1.5rem; 
    }
    .about-intro-content p { 
        color: var(--secondary-text-color, #6c757d); 
        font-size: 1.1rem; 
        line-height: 1.8; 
        margin-bottom: 2rem; 
    }
    .btn { 
        background: var(--accent-color, #007bff); /* Ana renk ile değiştirildi */
        color: white;
        padding: 1rem 2rem; 
        text-decoration: none; 
        font-weight: 500; 
        border-radius: 4px; 
        display: inline-block; 
        transition: all 0.3s ease;
        border: none;
    }
    .btn:hover { 
        background-color: #0056b3; /* Vurgu renginin koyusu */
        transform: translateY(-2px); /* Hafif yukarı kalkma efekti */
    }

    @media (min-width: 992px) {
        .about-intro-container { 
            grid-template-columns: 1fr 1.2fr; 
        }
        .about-intro-image {
            order: 2; /* Büyük ekranda resmi sağa alır */
        }
        .about-intro-content {
            order: 1; /* Büyük ekranda yazıyı sola alır */
        }
    }
</style>