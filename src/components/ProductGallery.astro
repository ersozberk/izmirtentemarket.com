---
// src/components/ProductGallery.astro
import { Image } from 'astro:assets';
// Görselleri src/assets klasörüne eklediğinizden emin olun.
// "Daha Fazla Göster" özelliğini test etmek için daha fazla görsel ekledim.
import roof1 from '../../public/images/roof-1.jpg';
import roof2 from '../../public/images/roof-2.jpg';
import roof3 from '../../public/images/roof-3.jpg'; // Yeni görsel
import glazing1 from '../../public/images/glazing-1.jpg';
import glazing2 from '../../public/images/glazing-2.jpg';
import glazing3 from '../../public/images/glazing-3.jpg'; // Yeni görsel
import screen1 from '../../public/products/gallery/sabit-1.jpg';
import screen2 from '../../public/products/gallery/karpuz-1.jpg';
import screen3 from '../../public/products/gallery/koruklu-tente-1.jpg'; // Yeni görsel
import screen4 from '../../public/products/gallery/kasetli-tente-1.jpg'; // Yeni görsel
---
<section class="product-gallery">
    <div class="container">
        <div class="gallery-header">
            <div class="gallery-text">
                <h2>Uygulamalarımız</h2>
                <p>Ürünlerimiz, hafif ve dayanıklı malzemeler kullanılarak, size özel dış mekan yaşam alanları yaratmak için tasarlanmıştır.</p>
            </div>
        </div>
        
        <nav class="gallery-nav">
            
            <button data-filter="roof">Bioklimatik</button>
            <button data-filter="glazing">Pergola</button>
            <button data-filter="screen">Tente</button>
        </nav>

        <div class="gallery-grid">
            <a class="gallery-item" data-category="roof"><Image src={roof1} alt="Çatı Sistemi Projesi 1" format="webp"/></a>
            <a class="gallery-item" data-category="screen"><Image src={screen1} alt="Gölgeleme Sistemi Projesi 1" format="webp"/></a>
            <a class="gallery-item" data-category="glazing"><Image src={glazing1} alt="Cam Sistemi Projesi 1" format="webp"/></a>
            <a class="gallery-item" data-category="roof"><Image src={roof2} alt="Çatı Sistemi Projesi 2" format="webp"/></a>
            <a class="gallery-item" data-category="glazing"><Image src={glazing2} alt="Cam Sistemi Projesi 2" format="webp"/></a>
            <a class="gallery-item" data-category="screen"><Image src={screen2} alt="Gölgeleme Sistemi Projesi 2" format="webp"/></a>
            <a class="gallery-item" data-category="roof"><Image src={roof3} alt="Çatı Sistemi Projesi 3" format="webp"/></a>
            <a lass="gallery-item" data-category="glazing"><Image src={glazing3} alt="Cam Sistemi Projesi 3" format="webp"/></a>
            <a class="gallery-item" data-category="screen"><Image src={screen3} alt="Gölgeleme Sistemi Projesi 3" format="webp"/></a>
            <a class="gallery-item" data-category="screen"><Image src={screen4} alt="Gölgeleme Sistemi Projesi 4" format="webp"/></a>
        </div>
        
        <div class="load-more-container">
            <button id="load-more-btn" class="load-more-btn">Daha Fazla Göster</button>
        </div>
    </div>
</section>

<!-- Modal ekle -->
<div id="gallery-modal" class="gallery-modal">
    <span class="gallery-modal-close" tabindex="0" aria-label="Kapat">&times;</span>
    <img id="gallery-modal-img" src="" alt="Büyük Görsel" />
</div>

<script is:inline>
    function setupGallery() {
        const gallery = document.querySelector('.product-gallery');
        if (!gallery || gallery.dataset.initialized === 'true') {
            return; // Galeri yoksa veya zaten kurulmuşsa tekrar çalıştırma
        }

        const filterButtons = gallery.querySelectorAll('.gallery-nav button');
        const galleryItems = Array.from(gallery.querySelectorAll('.gallery-grid .gallery-item'));
        const loadMoreBtn = gallery.querySelector('#load-more-btn');

        // Sabit: Başlangıçta ve her "daha fazla" tıklandığında kaç resim gösterileceği
        const ITEMS_PER_PAGE = 6;
        let visibleItemsCount = ITEMS_PER_PAGE;
        let currentFilter = 'all';

        // Galeriyi güncelleyen ana fonksiyon
        function updateGalleryView() {
            // Önce filtreye uyan elemanları bulalım
            const filteredItems = galleryItems.filter(item => 
                currentFilter === 'all' || item.dataset.category === currentFilter
            );

            // Tüm elemanları gizleyelim
            galleryItems.forEach(item => item.classList.add('hidden'));
            
            // Sadece gösterilmesi gerekenleri görünür yapalım
            filteredItems.slice(0, visibleItemsCount).forEach(item => {
                item.classList.remove('hidden');
            });

            // "Daha Fazla Göster" butonunu yönetelim
            if (filteredItems.length > visibleItemsCount) {
                loadMoreBtn.style.display = 'inline-block';
            } else {
                loadMoreBtn.style.display = 'none';
            }
        }

        // Filtre butonlarına tıklama olayı
        filterButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Aktif butonu değiştir
                filterButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');

                // Filtreyi ve görünür sayısını sıfırla
                currentFilter = button.dataset.filter;
                visibleItemsCount = ITEMS_PER_PAGE;
                
                // Galeriyi yeni filtreyle güncelle
                updateGalleryView();
            });
        });

        // "Daha Fazla Göster" butonuna tıklama olayı
        loadMoreBtn.addEventListener('click', () => {
            visibleItemsCount += ITEMS_PER_PAGE;
            updateGalleryView();
        });

        // Modal fonksiyonları
        const modal = document.getElementById('gallery-modal');
        const modalImg = document.getElementById('gallery-modal-img');
        const modalClose = document.querySelector('.gallery-modal-close');

        function openModal(src, alt) {
            modalImg.src = src;
            modalImg.alt = alt;
            modal.classList.add('is-open');
            document.body.classList.add('no-scroll');
        }
        function closeModal() {
            modal.classList.remove('is-open');
            modalImg.src = '';
            document.body.classList.remove('no-scroll');
        }
        modalClose.addEventListener('click', closeModal);
        modalClose.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') closeModal(); });
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

        // Sadece çift tıklama/double tap ile açılır pencere
        galleryItems.forEach(item => {
            const img = item.querySelector('img');
            if (!img) return;
            // Webde çift tıklama
            item.addEventListener('dblclick', (e) => {
                e.preventDefault();
                openModal(img.src, img.alt);
            });
            // Mobilde çift dokunma için
            let lastTap = 0;
            item.addEventListener('touchend', (e) => {
                const currentTime = new Date().getTime();
                const tapLength = currentTime - lastTap;
                if (tapLength < 400 && tapLength > 0) {
                    e.preventDefault();
                    openModal(img.src, img.alt);
                }
                lastTap = currentTime;
            });
        });

        // Başlangıç durumu için galeriyi ilk kez yükle
        updateGalleryView();
        gallery.dataset.initialized = 'true';
    }

    // Astro'nun sayfa geçişlerinde de çalışması için
    document.addEventListener('astro:page-load', setupGallery);
    // İlk yüklemede çalışması için (opsiyonel, page-load genellikle yeterlidir)
    setupGallery();
</script>

<style>
    .product-gallery { 
        padding: 6rem 0; 
        background-color: #f8f9fa; /* Hafif bir arkaplan rengi */
    }
    .gallery-header { 
        text-align: center; 
        margin-bottom: 3rem; 
    }
    .gallery-text h2 { 
        font-size: 2.5rem; 
        font-weight: 600; /* Biraz daha kalın */
    }
    .gallery-text p { 
        color: var(--secondary-text-color, #6c757d); 
        max-width: 600px; 
        margin: 1rem auto 0; 
        line-height: 1.8; 
    }
    
    /* GÜNCELLEME: Buton menüsü ortalandı ve stili değiştirildi */
    .gallery-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap; /* Mobilde alt satıra geçmesi için */
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .gallery-nav button {
        padding: 0.75rem 1.75rem;
        font-size: 1rem;
        font-weight: 500;
        color: #495057;
        background-color: white;
        border: 1px solid #dee2e6;
        border-radius: 99px; /* Yuvarlak hap şeklinde */
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .gallery-nav button:hover {
        background-color: #e9ecef;
        border-color: #ced4da;
    }

    .gallery-nav button.active {
        background-color: var(--accent-color, #007bff);
        color: white;
        border-color: var(--accent-color, #007bff);
        box-shadow: 0 4px 10px rgba(0, 123, 255, 0.25);
    }
    /* --- Bitiş: Buton menüsü güncellemesi --- */

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        gap: 1.5rem;
    }

    .gallery-item {
        display: block;
        overflow: hidden;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        /* GÜNCELLEME: Animasyon eklendi */
        transition: opacity 0.4s ease, transform 0.4s ease;
    }

    /* GÜNCELLEME: Gizlenen elemanlar için yeni stil */
    .gallery-item.hidden {
        opacity: 0;
        transform: scale(0.9);
        pointer-events: none; /* Tıklamayı engelle */
        display: none; /* Yer kaplamaması için */
    }

    .gallery-item img {
        width: 200%;
        aspect-ratio: 4/3;
        object-fit: cover;
        transition: transform 0.4s ease;
        display: block;
    }
    .gallery-item:hover img {
        transform: scale(1.35);
    }
    
    /* "Daha Fazla Göster" Butonu Stilleri */
    .load-more-container {
        text-align: center;
        margin-top: 3rem;
    }
    .load-more-btn {
        padding: 0.8rem 2rem;
        font-size: 1rem;
        font-weight: 500;
        color: white;
        background-color: var(--text-color, #212529);
        border: 1px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .load-more-btn:hover {
        background-color: var(--secondary-text-color, #6c757d);
    }

    /* Mobilde görseller daha büyük */
    @media (max-width: 600px) {
        .gallery-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .gallery-item img {
            width: 100vw;
            max-width: 100vw;
            height: 60vw;
            aspect-ratio: 4/3;
            object-fit: cover;
            border-radius: 16px;
        }
    }

    /* Modal stilleri */
    .gallery-modal {
        display: none;
        position: fixed;
        z-index: 2000;
        left: 0; top: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.85);
        justify-content: center;
        align-items: center;
        transition: opacity 0.3s;
        opacity: 0;
        pointer-events: none;
    }
    .gallery-modal.is-open {
        display: flex;
        opacity: 1;
        pointer-events: auto;
    }
    .gallery-modal img {
        max-width: 90vw;
        max-height: 80vh;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        background: white;
        padding: 1rem;
    }
    .gallery-modal-close {
        position: absolute;
        top: 2rem;
        right: 2rem;
        font-size: 3rem;
        color: white;
        cursor: pointer;
        z-index: 2010;
        background: none;
        border: none;
        outline: none;
        transition: color 0.2s;
    }
    .gallery-modal-close:hover, .gallery-modal-close:focus {
        color: #007bff;
    }
    body.no-scroll { overflow: hidden; }
</style>