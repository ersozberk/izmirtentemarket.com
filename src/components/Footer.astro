---
// src/components/Footer.astro (Yeniden Yazılmış, Kaliteli Versiyon)
const year = new Date().getFullYear();
---
<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col" id="about-col">
                <a href="/" class="footer-logo">
                    <!-- public klasörüne 'logo-white.svg' adında, şeffaf arkaplanlı beyaz bir logo ekleyin -->
                    <img src="../../public/logo.png" alt="İTM Architecture Beyaz Logo" />
                </a>
                <p class="footer-motto">Yaşam alanlarınıza değer katan modern gölgelendirme sistemleri. Kalite ve estetiği bir arada sunuyoruz.</p>
                <div class="social-links">
                    <a href="#" aria-label="Facebook" title="Facebook">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3l-.5 3h-2.5v6.8A10 10 0 0 0 22 12z"></path></svg>
                    </a>
                    <a href="#" aria-label="Instagram" title="Instagram">
