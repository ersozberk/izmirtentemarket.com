---
// src/components/ServicesSlider.astro
import { Image } from 'astro:assets';
// Kartlar için görselleri assets klasörüne atın
import tasarimImage from '../../public/images/tasarim.webp';
import montajImage from '../../public/images/montaj.webp';
import tamirImage from '../../public/images/tamir.webp';
---
<section class="services-slider-section">
    <div class="swiper services-swiper">
        <div class="swiper-wrapper">
            <div class="swiper-slide">
                <div class="service-card">
                    <div class="card-image">
                        <Image src={tasarimImage} alt="Özel Tasarım ve Projelendirme" format="webp"/>
                        <div class="card-logo">İTM</div>
                    </div>
                    <div class="card-content">
                        <h3>Tasarım & Projelendirme</h3>
                        <p>Mekanınıza özel, estetik ve fonksiyonel projelerle hayallerinizi gerçeğe dönüştürüyoruz.</p>
                        <a href="/hizmetler/tasarim">DETAYLAR +</a>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <div class="service-card">
                    <div class="card-image">
                        <Image src={montajImage} alt="Profesyonel Montaj ve Kurulum" format="webp"/>
                        <div class="card-logo">İTM</div>
                    </div>
                    <div class="card-content">
                        <h3>Profesyonel Montaj</h3>
                        <p>Uzman ekibimiz, ürünlerinizin montajını titizlikle ve güvenle gerçekleştirir.</p>
                        <a href="/hizmetler/montaj">DETAYLAR +</a>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <div class="service-card">
                    <div class="card-image">
                        <Image src={tamirImage} alt="Tente Tamiri ve Bakım" format="webp"/>
                        <div class="card-logo">İTM</div>
                    </div>
                    <div class="card-content">
                        <h3>Tamir & Bakım</h3>
                        <p>Mevcut sistemleriniz için her türlü tamir ve periyodik bakım hizmeti sunuyoruz.</p>
                        <a href="/hizmetler/tamir">DETAYLAR +</a>
                    </div>
                </div>
            </div>
            </div>
        <div class="swiper-pagination"></div>
    </div>
</section>

<style>
    .services-slider-section { padding: 6rem 0; background-color: #f8f9fa; }
    .swiper-slide { height: auto; display: flex; } /* Kartların eşit yükseklikte olması için */
    .service-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        width: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .service-card:hover {
        transform: translateY(-10px); /* Havaya kalkma efekti */
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .card-image { position: relative; }
    .card-image img { width: 100%; height: 250px; object-fit: cover; }
    .card-logo {
        position: absolute;
        top: 1rem;
        left: 1rem;
        width: 60px;
        height: 40px;
        background-color: var(--accent-color);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.5rem;
        font-weight: bold;
        border-radius: 4px;
        transition: transform 0.4s ease;
    }
    .service-card:hover .card-logo {
        transform: rotate(360deg); /* Logo dönme efekti */
    }
    .card-content { padding: 2rem; flex-grow: 1; display: flex; flex-direction: column; }
    .card-content h3 { font-size: 1.3rem; margin-top: 0; }
    .card-content p { color: var(--secondary-text-color); flex-grow: 1; }
    .card-content a { color: var(--accent-color); font-weight: bold; text-decoration: none; margin-top: 1rem; }
    .swiper-pagination { position: static; margin-top: 2rem; }
    .swiper-pagination-bullet-active { background-color: var(--accent-color); }
</style>

<script>
    import Swiper from 'swiper';
    import { Autoplay, Pagination } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/pagination';

    const swiper = new Swiper('.services-swiper', {
        modules: [Autoplay, Pagination],
        loop: true,
        slidesPerView: 1,
        spaceBetween: 30,
        pagination: {
            el: '.swiper-pagination',
            clickable: true,
        },
        autoplay: {
            delay: 3000,
            disableOnInteraction: false,
        },
        breakpoints: {
            768: {
                slidesPerView: 2,
            },
            1024: {
                slidesPerView: 3,
            },
        },
    });
</script>