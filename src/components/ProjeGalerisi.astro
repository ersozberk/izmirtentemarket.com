---
// src/components/ProjeGalerisi.astro
import { Image } from 'astro:assets';

import proje1 from '../../public/images/proje-1.jpg';
import proje2 from '../../public/images/proje-2.jpg';
import proje3 from '../../public/images/proje-3.jpg';
---
<section class="gallery">
    <div class="container">
        <div class="section-header">
            <span class="subtitle">Referans Projeler</span>
            <h2>Hayata Geçirdiğimiz Mekanlar</h2>
        </div>
    </div>
    <div class="gallery-grid">
        <a href="/projeler/proje-1" class="gallery-item">
            <Image src={proje1} alt="İzmir Alaçatı'da tamamlanan bioklimatik pergola projesi" format="webp" class="gallery-image" />
            <div class="overlay"><h3>Alaçatı Villa Projesi</h3></div>
        </a>
        <a href="/projeler/proje-2" class="gallery-item">
            <Image src={proje2} alt="Çeşme'de bir restoran için yapılan motorlu tente uygulaması" format="webp" class="gallery-image" />
            <div class="overlay"><h3>Çeşme Restoran Projesi</h3></div>
        </a>
        <a href="/projeler/proje-3" class="gallery-item">
            <Image src={proje3} alt="Urla'da kış bahçesi ve rolling roof sistemi" format="webp" class="gallery-image" />
            <div class="overlay"><h3>Urla Kış Bahçesi Projesi</h3></div>
        </a>
    </div>
</section>

<style>
    .gallery {
        padding: 4rem 0;
        background-color: var(--secondary-bg);
    }
    .gallery-grid {
        display: flex;
        flex-direction: column; /* MOBİL İÇİN DİKEY SIRALAMA */
        gap: 1rem;
    }
    .gallery-item {
        position: relative;
        display: block;
        overflow: hidden;
        /* MOBİLDE EKRANIN ÇOĞUNU KAPLAYAN BÜYÜK GÖRSELLER */
        height: 70vh;
        border-radius: 12px;
    }
    .gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease-in-out;
    }
    .gallery-item:hover .gallery-image {
        transform: scale(1.05);
    }
    .overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 2rem;
        background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 50%);
        color: white;
    }
    .overlay h3 {
        font-size: 1.8rem;
    }

    /* MASAÜSTÜ UYUMU */
    @media (min-width: 1024px) {
        .gallery-grid {
            display: grid;
            grid-template-columns: 2fr 1fr; /* Asimetrik güzel bir görünüm */
            gap: 1.5rem;
            padding: 0 1rem; /* Kenarlara boşluk */
        }
        .gallery-item {
            height: 500px; /* Sabit yükseklik */
        }
        .gallery-item:first-child {
            grid-column: 1 / 2;
            grid-row: 1 / 3;
            height: auto; /* Yüksekliği diğerlerine göre ayarla */
        }
        .gallery-item:nth-child(2) {
            grid-column: 2 / 3;
            grid-row: 1 / 2;
        }
        .gallery-item:nth-child(3) {
            grid-column: 2 / 3;
            grid-row: 2 / 3;
        }
    }
</style>