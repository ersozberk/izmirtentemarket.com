---
---
<section class="team-section">
    <div class="container">
        <div class="section-title">
            <h2>Ekibimiz</h2>
            <p>Projelerinizi hayata geçiren deneyimli ve tutkulu kadromuz.</p>
        </div>
        <div class="team-grid">
            
            <div class="team-member">
                <div class="member-initials" style="background-color: #007bff;">
                    <span>RÖ</span>
                </div>
                <h3>Ramazan Öztürk</h3>
                <p>Kurucu & Proje Yöneticisi</p>
            </div>

            <div class="team-member">
                <div class="member-initials" style="background-color: #6c757d;">
                    <span>AY</span>
                </div>
                <h3>Ayşe Yılmaz</h3>
                <p>Mimar</p>
            </div>

            <div class="team-member">
                <div class="member-initials" style="background-color: #28a745;">
                    <span>AÇ</span>
                </div>
                <h3>Ahmet Çelik</h3>
                <p>Uygulama Sorumlusu</p>
            </div>

        </div>
    </div>
</section>

<style>
    .team-section { 
        padding: 6rem 0; 
        background-color: #f8f9fa;
    }
    .section-title { 
        text-align: center; 
        margin-bottom: 4rem; 
    }
    .section-title h2 { 
        font-size: 2.5rem; 
        font-weight: 600; 
    }
    .section-title p { 
        font-size: 1.1rem; 
        color: #6c757d; 
        max-width: 600px; 
        margin: 1rem auto 0; 
    }
    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        justify-items: center;
    }
    .team-member { 
        text-align: center; 
    }
    
    /* Resim yerine baş harfleri gösteren daire stili */
    .member-initials {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        margin: 0 auto 1.5rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        color: white;
    }
    .member-initials span {
        font-size: 4rem;
        font-weight: 600;
    }

    .team-member h3 { 
        font-size: 1.5rem; 
        font-weight: 500; 
        margin-bottom: 0.5rem; 
    }
    .team-member p { 
        color: #6c757d; 
    }
</style>