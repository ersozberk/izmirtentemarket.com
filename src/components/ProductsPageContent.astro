---
// Hata vermeyen "akıllı" resim bileşenimizi import ediyoruz.
import SmartImage from './SmartImage.astro';

// Ürün kategorileri. Yeni eklemek veya çıkarmak için burayı düzenleyebilirsiniz.
const productCategories = [
  {
    title: "Bioklimatik Pergola",
    description: "Alüminyum panelleriyle güneş ışığını, havalandırmayı ve yağmur korumasını mükemmel şekilde kontrol eden en üst düzey teknolojiye sahip sistemler.",
    image: "/images/products/bioklimatik.jpg",
    url: "/urunler/bioklimatik-pergola", // Bu sayfanın ileride oluşturulması gerekecek
  },
  {
    title: "Pergola Sistemleri",
    description: "Açılır-kapanır tavan sistemleri ile dış mekanlarınızı dört mevsim kullanılabilir hale getirir.",
    image: "/images/products/pergola.jpg",
    url: "/urunler/pergola-sistemleri",
  },
  {
    title: "Kasetli Tente",
    description: "Kapandığında kumaşı ve mekanizmayı koruyan, modern ve şık tente çözümü.",
    image: "/images/products/kasetli-tente.jpg",
    url: "/urunler/kasetli-tente",
  },
  {
    title: "Klasik Tente",
    description: "Geniş gölge alanı sunan, en çok tercih edilen, fonksiyonel mafsallı tente modeli.",
    image: "/images/products/klasik-tente.jpg",
    url: "/urunler/klasik-tente",
  },
  {
    title: "Karpuz Tente",
    description: "Mekanlara estetik ve nostaljik bir hava katan, dekoratif tente çözümü.",
    image: "/images/products/karpuz-tente.jpg",
    url: "/urunler/karpuz-tente",
  },
  {
    title: "Sabit Tente",
    description: "Kapı girişleri ve pencereler için kalıcı, dayanıklı ve şık koruma sağlar.",
    image: "/images/products/sabit-tente.jpg",
    url: "/urunler/sabit-tente",
  },
  {
    title: "Win Tente",
    description: "Dikey çalışan, rüzgar ve güneş kontrolü için ideal, modern ve pratik bir sistem.",
    image: "/images/products/win-tente.jpg",
    url: "/urunler/win-tente",
  },
  {
    title: "Körüklü Tente",
    description: "Yanlardan kapanabilen yapısıyla mahremiyet ve ekstra koruma sunar.",
    image: "/images/products/koruklu-tente.jpg",
    url: "/urunler/koruklu-tente",
  }
];
---

<section class="products-page">
    <div class="container">
        <div class="page-header">
            <h1>Ürünlerimiz</h1>
            <p>Mekanlarınıza değer katan, estetik ve dayanıklı dış mekan çözümlerimizle tanışın.</p>
        </div>
        <div class="products-grid">
            {productCategories.map(category => (
                <div class="product-card">
                    <div class="card-image-wrapper">
                        <SmartImage src={category.image} alt={category.title} width="400" height="300" />
                    </div>
                    <div class="card-content">
                        <h2 class="card-title">{category.title}</h2>
                        <p class="card-description">{category.description}</p>
                    </div>
                    <div class="card-footer">
                        <a href={category.url} class="btn">Modelleri Gör</a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .products-page { 
        padding: 6rem 0; 
        background-color: #f8f9fa;
    }
    .page-header { 
        text-align: center; 
        margin-bottom: 4rem; 
    }
    .page-header h1 { 
        font-size: 3rem; 
        font-weight: 600; 
    }
    .page-header p { 
        font-size: 1.2rem; 
        color: var(--secondary-text-color, #6c757d); 
        max-width: 600px; 
        margin: 1rem auto 0; 
    }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }
    .product-card {
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid var(--border-color, #e9ecef);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }
    .card-image-wrapper img {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }
    .card-content {
        padding: 1.5rem;
        flex-grow: 1; /* İçeriğin kartı doldurmasını sağlar */
    }
    .card-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
    .card-description {
        font-size: 1rem;
        color: var(--secondary-text-color, #6c757d);
        line-height: 1.6;
    }
    .card-footer {
        padding: 0 1.5rem 1.5rem 1.5rem;
    }
    .btn {
        display: inline-block;
        width: 100%;
        text-align: center;
        padding: 0.8rem 1.5rem;
        background-color: var(--accent-color, #007bff);
        color: white;
        text-decoration: none;
        font-weight: 500;
        border-radius: 4px;
        transition: background-color 0.2s ease;
    }
    .btn:hover {
        background-color: #0056b3;
    }
</style>