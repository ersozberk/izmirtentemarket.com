---
import SmartImage from './SmartImage.astro';

interface Props {
  title: string;
  heroImage: string;
}

const { title, heroImage } = Astro.props;
---
<section class="service-detail-hero" style={`background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url(${heroImage})`}>
    <div class="container">
        <h1>{title}</h1>
    </div>
</section>

<section class="service-detail-content">
    <div class="container content-grid">
        <div class="main-content prose">
            <slot />
        </div>
        <aside class="sidebar">
            <div class="sidebar-widget">
                <h3>Neden Biz?</h3>
                <ul>
                    <li><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Yılların Tecrübesi</li>
                    <li><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22V12"></path></svg> Kaliteli Malzeme</li>
                    <li><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> Müşteri Memnuniyeti Garantisi</li>
                    <li><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> Hızlı ve Profesyonel Destek</li>
                </ul>
            </div>
            <div class="sidebar-widget cta-widget">
                <h3>Projeniz mi Var?</h3>
                <p>Hayalinizdeki mekan için ilk adımı atın.</p>
                <a href="/iletisim" class="btn">Teklif Alın</a>
            </div>
        </aside>
    </div>
</section>

<style>
.service-detail-hero {
        position: relative;
        padding: 6rem 0;
        text-align: center;
        color: white;
        background-size: cover;
        background-position: center;
    }
    .service-detail-hero h1 { font-size: 3.5rem; font-weight: 700; position: relative; z-index: 2; }

    .service-detail-content { padding: 6rem 0; }
    .content-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
    }

    .main-content {
        order: 2; /* Mobilde sidebar üstte */
    }
    .sidebar {
        order: 1;
    }
    
    .prose { font-size: 1.1rem; line-height: 1.8; }
    .prose h2 { font-size: 2rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 1.5rem; }
    .prose p { margin-bottom: 1.5rem; color: #495057; }
    .prose ul { padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .prose li { margin-bottom: 0.75rem; }

    .sidebar-widget {
        background-color: #f8f9fa;
        padding: 2rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .sidebar-widget h3 { font-size: 1.5rem; font-weight: 600; margin: 0 0 1.5rem 0; }
    .sidebar-widget ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
    .sidebar-widget li { display: flex; align-items: center; font-weight: 500; }
    .sidebar-widget li svg { width: 20px; height: 20px; margin-right: 1rem; color: var(--accent-color, #007bff); }
    
    .cta-widget { background-color: #212931; color: white; }
    .cta-widget p { color: #adb5bd; }
    .btn {
        display: block; text-align: center; margin-top: 1.5rem; padding: 0.8rem; background-color: var(--accent-color, #007bff);
        color: white; text-decoration: none; font-weight: 500; border-radius: 4px; transition: background-color 0.2s ease;
    }
    .btn:hover { background-color: #0056b3; }

    @media(min-width: 992px) {
        .content-grid { grid-template-columns: 3fr 1fr; }
        .main-content { order: 1; }
        .sidebar { order: 2; }
    }
</style>