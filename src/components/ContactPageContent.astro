---
// Buradaki bilgileri kendi bilgilerinizle güncelleyin
const contactDetails = {
  address: "Çalıkuşu, 3168. Sk. No:8, 35110 Karabağlar/İzmir",
  phone: "0553 366 24 47",
  email: "help@izmirtentemarket.com",
};

// Formun çalışması için https://formspree.io/ adresinden alacağınız URL'yi buraya yapıştırın.
const formspreeEndpoint = "https://formspree.io/f/XXXXXXX";
---

<section class="page-header">
    <div class="container">
        <h1>Bize Ulaşın</h1>
        <p>Projeniz hakkında konuşmak, teklif almak veya aklınızdaki soruları sormak için buradayız.</p>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info">
                <h3>İletişim Bilgileri</h3>
                <p>Aşağıdaki kanallardan bize doğrudan ulaşabilir veya yan taraftaki formu doldurabilirsiniz.</p>
                <ul>
                    <li>
                        <span class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        </span>
                        <div class="info-text">
                            <strong>Adres</strong>
                            <span>{contactDetails.address}</span>
                        </div>
                    </li>
                    <li>
                        <span class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        </span>
                        <div class="info-text">
                            <strong>Telefon</strong>
                            <a href={`tel:${contactDetails.phone.replace(/\s/g, '')}`}>{contactDetails.phone}</a>
                        </div>
                    </li>
                    <li>
                        <span class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        </span>
                        <div class="info-text">
                            <strong>E-Posta</strong>
                            <a href={`mailto:${contactDetails.email}`}>{contactDetails.email}</a>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="contact-form-wrapper">
                <h3>Mesaj Gönderin</h3>
                <form action={formspreeEndpoint} method="POST" class="contact-form">
                    <div class="form-group">
                        <label for="name">Ad Soyad</label>
                        <input type="text" id="name" name="name" required />
                    </div>
                    <div class="form-group">
                        <label for="email">E-Posta Adresi</label>
                        <input type="email" id="email" name="email" required />
                    </div>
                    <div class="form-group">
                        <label for="message">Mesajınız</label>
                        <textarea id="message" name="message" rows="6" required></textarea>
                    </div>
                    <button type="submit" class="btn">Mesajı Gönder</button>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="map-section">
    <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12508.992934619115!2d27.110335655419927!3d38.38950909999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14bbdf7fb609f2bd%3A0x174ef1ba31d05549!2s%C4%B0zmir%20Tente%20Market!5e0!3m2!1str!2str!4v1759908627863!5m2!1str!2str"
        width="600" 
        height="450" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
    </iframe>
</section>

<style>
.page-header {
        padding: 4rem 0;
        text-align: center;
        background-color: #f8f9fa;
    }
    .page-header h1 { font-size: 3rem; font-weight: 600; margin-bottom: 1rem;}
    .page-header p { font-size: 1.2rem; color: #6c757d; max-width: 600px; margin: 0 auto; }

    .contact-section { padding: 6rem 0; }
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
    }
    
    .contact-info h3, .contact-form-wrapper h3 {
        font-size: 2rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }

    .contact-info ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .contact-info li { display: flex; align-items: flex-start; }
    .contact-info .icon {
        flex-shrink: 0;
        margin-right: 1.5rem;
        color: var(--accent-color, #007bff);
    }
    .info-text { display: flex; flex-direction: column; }
    .info-text strong { font-weight: 500; margin-bottom: 0.25rem; }
    .info-text span, .info-text a { 
        color: #6c757d;
        text-decoration: none;
        line-height: 1.6;
    }
    .info-text a:hover { text-decoration: underline; }

    .contact-form .form-group { margin-bottom: 1.5rem; }
    .contact-form label { display: block; margin-bottom: 0.5rem; font-weight: 500; }
    .contact-form input, .contact-form textarea {
        width: 100%;
        padding: 0.8rem 1rem;
        border: 1px solid #ced4da;
        border-radius: 4px;
        font-size: 1rem;
        font-family: inherit;
    }
    .contact-form input:focus, .contact-form textarea:focus {
        outline: none;
        border-color: var(--accent-color, #007bff);
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.25);
    }
    .btn {
        display: inline-block;
        padding: 0.8rem 2rem;
        background-color: var(--accent-color, #007bff);
        color: white;
        border: none;
        border-radius: 4px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }
    .btn:hover { background-color: #0056b3; }

    .map-section {
        width: 100%;
        height: 450px;
    }
    .map-section iframe {
        width: 100%;
        height: 100%;
    }

    @media(min-width: 992px) {
        .contact-grid {
            grid-template-columns: 1fr 1.5fr;
        }
    }
</style>